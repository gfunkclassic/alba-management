rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthed() { return request.auth != null; }
    function myProfile() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    function myRole() { return myProfile().role; }
    function myRoleGroup() { return myProfile().roleGroup; }
    function myTeam() { return myProfile().team_id; }

    // 관리자(최종 결재 권한): 구버전 role 및 신규 roleGroup 모두 허용
    function isAdmin() {
      return myRole() == 'FINAL_APPROVER' ||
             myRoleGroup() == 'approver_final' ||
             myRoleGroup() == 'approver_senior' ||
             myRoleGroup() == 'sys_admin';
    }
    // 시스템 관리자
    function isSysAdminUser() {
      return myRole() == 'SUPER_ADMIN' || myRoleGroup() == 'sys_admin';
    }
    // 팀 관리자
    function isTeamApproverUser() {
      return myRole() == 'TEAM_APPROVER' || myRoleGroup() == 'manager';
    }

    // 수임자 여부: delegations/{uid} 문서에서 is_active + 팀 확인
    function isActiveDelegatee(teamId) {
      let ref = /databases/$(database)/documents/delegations/$(request.auth.uid);
      return exists(ref) &&
        get(ref).data.is_active == true &&
        get(ref).data.team_id == teamId;
    }

    // ─── settings ──────────────────────────────────────────────
    match /settings/{docId} {
      allow read: if true;  // 로그인/가입 페이지에서 팀 목록을 읽기 위해 비인증 허용
      allow write: if isAuthed() && isAdmin();
    }

    // ─── users ─────────────────────────────────────────────────
    match /users/{uid} {
      allow read: if isAuthed();
      // 가입등록: 본인 UID로 PENDING 상태 문서 생성
      allow create: if isAuthed() && request.auth.uid == uid && (
        isAdmin() ||
        (request.resource.data.status == 'PENDING' &&
         !('role' in request.resource.data || request.resource.data.role == null) ||
         request.resource.data.get('role', null) == null)
      );
      // 본인 is_temp_password 업데이트
      allow update: if isAuthed() && request.auth.uid == uid &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['is_temp_password']);
      // FINAL_APPROVER: 계정 관리 (status, role, team_id 등)
      allow update: if isAuthed() && isAdmin();
      allow delete: if false;
    }

    // ─── leave_balance ─────────────────────────────────────────
    // 클라이언트는 읽기만 허용. 차감은 Cloud Functions에서만.
    match /leave_balance/{docId} {
      allow read: if isAuthed() && (
        resource.data.user_id == request.auth.uid ||
        isAdmin()
      );
      // 잔여 조정(수동)은 관리자 계정만 허용
      allow write: if isAuthed() && isAdmin();
    }

    // ─── leave_requests ────────────────────────────────────────
    match /leave_requests/{reqId} {
      allow read: if isAuthed() && (
        resource.data.user_id == request.auth.uid ||
        ((myRole() == 'TEAM_APPROVER' || myRoleGroup() == 'manager') && resource.data.team_id == myTeam()) ||
        isActiveDelegatee(resource.data.team_id) ||
        isAdmin()
      );
      // 생성: 본인이 본인 이름으로 SUBMITTED 상태로만 생성
      allow create: if isAuthed() &&
        request.resource.data.user_id == request.auth.uid &&
        request.resource.data.status == 'SUBMITTED';
      // 업데이트: 본인의 SUBMITTED → CANCELLED 취소만 허용
      // 나머지 모든 상태 변경(TEAM_APPROVED, FINAL_APPROVED, REJECTED)은 Functions 전용
      allow update: if isAuthed() &&
        resource.data.user_id == request.auth.uid &&
        resource.data.status == 'SUBMITTED' &&
        request.resource.data.status == 'CANCELLED' &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'updated_at']);
      // team_id 동기화: FINAL_APPROVER만 (시스템 팀명 변경 시)
      allow update: if isAuthed() && isAdmin() &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['team_id', 'updated_at']);
      allow delete: if false;
    }

    // ─── approvals 로그 ────────────────────────────────────────
    // 클라이언트에서 create 완전 차단. Cloud Functions에서만 생성.
    match /approvals/{docId} {
      allow read: if isAuthed() && (
        resource.data.actor_user_id == request.auth.uid ||
        isAdmin() ||
        get(/databases/$(database)/documents/leave_requests/$(resource.data.leave_request_id)).data.user_id == request.auth.uid
      );
      allow create, update, delete: if false;
    }

    // ─── delegations ───────────────────────────────────────────
    // 클라이언트 write 허용 (위임은 Functions 불필요 — 보안 위험 낮음)
    match /delegations/{toUserId} {
      // 위임 생성: TEAM_APPROVER가 본인 팀에만, 허용 필드 제한
      allow create: if isAuthed() &&
        (myRole() == 'TEAM_APPROVER' || myRoleGroup() == 'manager') &&
        request.resource.data.from_user_id == request.auth.uid &&
        request.resource.data.team_id == myTeam() &&
        request.resource.data.keys().hasOnly([
          'from_user_id', 'to_user_id', 'team_id',
          'is_active', 'start_date', 'end_date',
          'created_at', 'updated_at'
        ]);
      // 업데이트: 위임자 본인이 활성/기간 필드만 수정 가능
      allow update: if isAuthed() && (
        ((myRole() == 'TEAM_APPROVER' || myRoleGroup() == 'manager') &&
         resource.data.from_user_id == request.auth.uid &&
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['is_active', 'start_date', 'end_date', 'updated_at'])) ||
        // 관리자 시스템 팀명 변경에 따른 연동 업데이트
        (isAdmin() &&
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['team_id', 'updated_at']))
      );
      allow read: if isAuthed() && (
        resource.data.from_user_id == request.auth.uid ||
        resource.data.to_user_id == request.auth.uid ||
        isAdmin()
      );
      allow delete: if false;
    }

    // ─── senior_delegations (실장 위임) ────────────────────────
    // 실장(approver_senior)이 수임자를 지정해 자신의 슬롯을 대결 위임하는 구조
    match /senior_delegations/{toUserId} {
      // 실장 본인만 위임 생성/수정 가능 (from_user_id == 본인)
      allow create: if isAuthed() && isAdmin() &&
        request.resource.data.from_user_id == request.auth.uid &&
        request.resource.data.to_user_id == toUserId &&
        request.resource.data.keys().hasOnly([
          'from_user_id', 'to_user_id',
          'is_active', 'start_date', 'end_date',
          'created_at', 'updated_at'
        ]);
      allow update: if isAuthed() && isAdmin() &&
        resource.data.from_user_id == request.auth.uid &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['is_active', 'start_date', 'end_date', 'updated_at']);
      // 위임자(실장) 또는 수임자 본인만 읽기 가능
      allow read: if isAuthed() && (
        resource.data.from_user_id == request.auth.uid ||
        resource.data.to_user_id == request.auth.uid ||
        isAdmin()
      );
      allow delete: if false;
    }

    // ─── notifications ─────────────────────────────────────────
    // create/delete 클라이언트 차단. Cloud Functions에서만 생성.
    // 읽음 처리(is_read 업데이트)만 클라이언트 허용.
    match /notifications/{docId} {
      allow read: if isAuthed() && resource.data.to_user_id == request.auth.uid;
      allow update: if isAuthed() &&
        resource.data.to_user_id == request.auth.uid &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['is_read']);
      allow create: if isAuthed();
      allow delete: if isAuthed() && resource.data.to_user_id == request.auth.uid;
    }

    // ─── HR 직원 데이터 (인사 급여 시스템) ────────────────────────
    match /employees/{docId} {
      allow read: if isAuthed();
      allow write: if isAuthed() && isAdmin();
    }

    match /attendance/{docId} {
      allow read: if isAuthed();
      allow write: if isAuthed() && isAdmin();
    }

    match /leave_records/{docId} {
      allow read: if isAuthed();
      allow write: if isAuthed() && isAdmin();
    }

    match /leave_adjustments/{docId} {
      allow read: if isAuthed();
      allow write: if isAuthed() && isAdmin();
    }

    match /leave_carryovers/{docId} {
      allow read: if isAuthed();
      allow write: if isAuthed() && isAdmin();
    }

    match /payroll_status/{docId} {
      allow read: if isAuthed();
      allow write: if isAuthed() && isAdmin();
    }
  }
}
