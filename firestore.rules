rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthed() { return request.auth != null; }
    function myProfile() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    function myRole() { return myProfile().role; }
    function myTeam() { return myProfile().team_id; }

    // 수임자 여부: delegations/{uid} 문서에서 is_active + 팀 확인
    function isActiveDelegatee(teamId) {
      let ref = /databases/$(database)/documents/delegations/$(request.auth.uid);
      return exists(ref) &&
        get(ref).data.is_active == true &&
        get(ref).data.team_id == teamId;
    }

    // ─── settings ──────────────────────────────────────────
    match /settings/{docId} {
      allow read: if true;  // Allow unauthenticated read so login/register page can list teams
      allow write: if isAuthed() && myRole() == 'FINAL_APPROVER';
    }

    // ─── users ─────────────────────────────────────────────
    match /users/{uid} {
      allow get: if isAuthed() && (
        request.auth.uid == uid ||
        (myRole() == 'TEAM_APPROVER' && resource.data.team_id == myTeam()) ||
        myRole() == 'FINAL_APPROVER'
      );
      allow list: if isAuthed() && (
        myRole() == 'TEAM_APPROVER' || myRole() == 'FINAL_APPROVER'
      );
      // 자가등록: 본인 UID로 PENDING 상태 문서 생성
      allow create: if isAuthed() && request.auth.uid == uid && (
        myRole() == 'FINAL_APPROVER' ||
        (request.resource.data.status == 'PENDING' &&
         !('role' in request.resource.data || request.resource.data.role == null) ||
         request.resource.data.get('role', null) == null)
      );
      // 본인 is_temp_password 업데이트
      allow update: if isAuthed() && request.auth.uid == uid &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['is_temp_password']);
      // FINAL_APPROVER: 계정 관리 (status, role, team_id 등)
      allow update: if isAuthed() && myRole() == 'FINAL_APPROVER';
      allow delete: if false;
    }

    // ─── leave_balance ──────────────────────────────────────
    match /leave_balance/{docId} {
      allow read: if isAuthed() && (
        resource.data.user_id == request.auth.uid ||
        myRole() == 'FINAL_APPROVER'
      );
      allow write: if isAuthed() && myRole() == 'FINAL_APPROVER';
    }

    // ─── leave_requests ─────────────────────────────────────
    match /leave_requests/{reqId} {
      allow read: if isAuthed() && (
        resource.data.user_id == request.auth.uid ||
        (myRole() == 'TEAM_APPROVER' && resource.data.team_id == myTeam()) ||
        isActiveDelegatee(resource.data.team_id) ||
        myRole() == 'FINAL_APPROVER'
      );
      // 생성: 본인, SUBMITTED만
      allow create: if isAuthed() &&
        request.resource.data.user_id == request.auth.uid &&
        request.resource.data.status == 'SUBMITTED';
      allow update: if isAuthed() && (
        // ALBA 취소: SUBMITTED → CANCELLED
        (resource.data.user_id == request.auth.uid &&
         resource.data.status == 'SUBMITTED' &&
         request.resource.data.status == 'CANCELLED' &&
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'updated_at']))
        ||
        // TEAM_APPROVER: 본인 팀 SUBMITTED → TEAM_APPROVED/REJECTED
        (myRole() == 'TEAM_APPROVER' &&
         resource.data.team_id == myTeam() &&
         resource.data.status == 'SUBMITTED' &&
         (request.resource.data.status == 'TEAM_APPROVED' || request.resource.data.status == 'REJECTED') &&
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'updated_at']))
        ||
        // 수임자: 활성 위임 + 같은 팀 SUBMITTED → TEAM_APPROVED/REJECTED
        (isActiveDelegatee(resource.data.team_id) &&
         resource.data.status == 'SUBMITTED' &&
         (request.resource.data.status == 'TEAM_APPROVED' || request.resource.data.status == 'REJECTED') &&
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'updated_at']))
        ||
        // FINAL_APPROVER 팀 대행: SUBMITTED → TEAM_APPROVED/REJECTED
        (myRole() == 'FINAL_APPROVER' &&
         resource.data.status == 'SUBMITTED' &&
         (request.resource.data.status == 'TEAM_APPROVED' || request.resource.data.status == 'REJECTED') &&
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'updated_at']))
        ||
        // FINAL_APPROVER 최종 승인: TEAM_APPROVED → FINAL_APPROVED/REJECTED
        (myRole() == 'FINAL_APPROVER' &&
         resource.data.status == 'TEAM_APPROVED' &&
         (request.resource.data.status == 'FINAL_APPROVED' || request.resource.data.status == 'REJECTED') &&
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'updated_at']))
      );
      allow delete: if false;
    }

    // ─── approvals 로그 ─────────────────────────────────────
    match /approvals/{docId} {
      allow create: if isAuthed() && (
        myRole() == 'TEAM_APPROVER' ||
        myRole() == 'FINAL_APPROVER' ||
        isActiveDelegatee(request.resource.data.team_id)
      );
      allow read: if isAuthed() && (
        resource.data.actor_user_id == request.auth.uid ||
        myRole() == 'FINAL_APPROVER'
      );
      allow update, delete: if false;
    }

    // ─── delegations ───────────────────────────────────────
    match /delegations/{toUserId} {
      // 위임 생성/수정: TEAM_APPROVER가 본인을 from_user_id로 하는 위임만
      allow create: if isAuthed() &&
        myRole() == 'TEAM_APPROVER' &&
        request.resource.data.from_user_id == request.auth.uid &&
        request.resource.data.team_id == myTeam();
      allow update: if isAuthed() &&
        myRole() == 'TEAM_APPROVER' &&
        resource.data.from_user_id == request.auth.uid;
      // 본인(위임자/수임자) 또는 FINAL_APPROVER
      allow read: if isAuthed() && (
        resource.data.from_user_id == request.auth.uid ||
        resource.data.to_user_id == request.auth.uid ||
        myRole() == 'FINAL_APPROVER'
      );
      allow delete: if false;
    }

    // ─── notifications ──────────────────────────────────────
    match /notifications/{docId} {
      allow create: if isAuthed();
      allow read: if isAuthed() && resource.data.to_user_id == request.auth.uid;
      allow update: if isAuthed() &&
        resource.data.to_user_id == request.auth.uid &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['is_read']);
      allow delete: if false;
    }
  }
}
